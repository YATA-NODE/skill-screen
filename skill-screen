#!/usr/bin/env bash
# skill-screen — エージェント skill 向けの、ローカル・透明・単一ファイルの導入前スクリーナ。
#
# すべてがこの 1 ファイルに、隠さず、4 つのセクションで収まっている:
#   (1) DETECTION RULES   読める grep ルールセット — カスタマイズはここを編集する
#   (2) INSPECTION        全ファイルをルールに照合する唯一の grep
#   (3) SCAN ENGINE       走査・ハッシュ・マスク・fail-closed な verdict(凍結コア)
#   (4) DRIVER            引数解析・出力(read-only、対象は書き換えない)
#
# skill/拡張のディレクトリを走査し、ルールセットを適用して verdict を出力する。
# ここは MECHANICAL(機械的)段のみ = 候補を炙り出すだけ。意図の判定は、JSON と
# SKILL.md 内の Stage 2 プロンプトを LLM に渡す(あるいは自分で読む)。
#
# verdict は安全の保証ではない。"no_signal" は「どのルールにも一致しなかった」で
# あって「安全」ではない。何が flag されたかを読み、判断すること。
#
# 依存: bash, grep, sha256sum, timeout(coreutils)。jq は任意(あればきれいな
# JSON、無ければ最小 JSON へ degrade)。ネットワーク・リモートサービスは一切なし。
set -u

# このスクリプト自身のディレクトリを解決する(同梱 SKILL.md の位置特定にのみ使う)。
_self_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
  cat <<'EOF'
skill-screen — エージェント skill 向けの、ローカル・透明な導入前スクリーナ。
skill-screen — local, transparent pre-install screen for agent skills.

使い方 / Usage:
  skill-screen --target <dir> [options]

オプション / Options:
  --target <dir>        検査する skill/拡張のディレクトリ(必須)。
                        Directory of the skill/extension to screen (required).
  --include-secret-scan 同梱された認証情報も走査する(出力ではマスク)。
                        Also scan for shipped credentials (masked in output).
  --json                要約の代わりに機械可読の JSON を出力する。
                        Print the machine-readable JSON instead of a summary.

このツールは対象を一切書き換えない read-only スキャナです(作成・移動・削除をしない)。
信用するまで自分で別フォルダに隔離してから検査してください(下記 NOTE 参照)。
This tool is a read-only scanner: it never creates, moves, or deletes your files.
Isolate an untrusted skill into a separate folder yourself BEFORE scanning it.
  -h, --help            このヘルプを表示する。 / Show this help.

終了コード / Exit codes:  0 no_signal   1 review_needed   2 do_not_install   3 scan-error
EOF
}

# ============================================================================
# (1) DETECTION RULES(検出ルール)— flag 対象のカスタマイズはここを編集する
# ============================================================================

# 検出ルールセットの全体を、隠さずここに置く。
#
# これが skill-screen の透明性の約束: skill を flag しうるルールは、すべて読める
# POSIX 拡張正規表現(ERE)としてここに在る。MECHANICAL 段に隠れたモデルもリモート
# サービスも無い。読んで、監査して、fork してよい。flag 対象を変えたいなら下の配列
# を編集する — それ以外は何も変えなくてよい。
#
# 各エントリの形式:  category|severity|extended-regex
#   - category : 短く安定した id。出力に表示され stage-2 プロンプトでも使う
#   - severity : "blocked"(導入不可)または "warning"(導入前に読む)
#   - regex    : 各走査ファイルに `grep -nE` で照合する
#
# 設計メモ(なぜルールセットを小さく保守的にするか):
#   - 高 recall + 意図的な false positive。stage 1 は *候補* を flag するだけで、意図
#     は人間か LLM(stage 2)が判定する。攻撃を *記述しているだけ* の skill
#     (「'ignore previous instructions' とは書くな」)もここで一致する — それでよい、
#     stage 2 が仕分ける。
#   - 非英語(日本語)パターンは warning のみ。語彙ベースの照合は言い換えで容易に
#     回避できるため、JP の一致単独で "blocked" に昇格させない。
#   - このリストは言語や言い回しを網羅 *しない* ことを意図している。全部読める
#     スクリーンは、読めない巨大なリストに勝る。

# パターン集合または出力形状が変わったら bump する(走査出力に記録され、再チェック
# 判定に使う)。
#   v1 (initial): EN blocked 3 + EN warning 5 + JP warning 4(JP は opt-in)
#   v2: JP warning を既定適用; JSON 出力から "profile" フィールドを削除
#   v3: パターン照合を case-insensitive 化(secret マーカーは case-sensitive のまま);
#       remote-exec-indirect を追加; NUL 入りの指示/実行ファイルと同梱 credential
#       ファイルを red flag 化; JSON に red_flags[] を追加
#   v4: NUL red flag を role 非依存化 — 既知バイナリ拡張子(画像/フォント/データ)だけを
#       除外し、role=other の config/manifest/拡張子なしファイルに混ぜた NUL 隠蔽も捕捉する
#       (v3 は instruction/executable 限定で、setup.conf 等が素通りしていた);
#       同梱 credential ファイル名に .netrc / credentials / service-account.json 等を追加
patterns::schema_version() { echo "4"; }

# BLOCKED — 導入をブロックする。典型的な prompt-injection / リモートコード実行。
# remote-exec は「取得して即シェルに流す」形(パイプ 1 段の寄り道まで許容)、
# remote-exec-indirect は「落としてから同一行で実行 / eval / プロセス置換」の形。
# いずれも 1 行の素直な書き方だけを見る: 難読化(base64・文字列分割・変数経由)は
# 意図的に範囲外(制限事項 参照)。行連結は `&&` / `;` に限り、`||`(失敗時の
# フォールバック)は一致させない。
SKC_BLOCKED_PATTERNS=(
  'instruction-override|blocked|(ignore|disregard) (all |any )?(previous|prior|above|earlier) (instruction|prompt|direction|rule)|forget (everything|all|your) (prior|previous|instruction|rule)|override (the )?(system|previous|prior) (prompt|instruction)'
  'role-change|blocked|you are now (an?|the)|act as (an?|the|if)|pretend (to be|you are)|from now on,? you (are|will|must|should)|disregard your (role|persona|identity|instruction)'
  'remote-exec|blocked|(curl|wget)[^|]*\|([[:space:]]*[[:alnum:]_][^|]*\|)?[[:space:]]*(sudo[[:space:]]+)?(sh|bash|zsh)([[:space:]]|$)'
  'remote-exec-indirect|blocked|(curl|wget).*(-o|-O|>).*(&&|;)[[:space:]]*(sudo[[:space:]]+)?(sh|bash|zsh)([[:space:]]|$)|eval[[:space:]]+.*(curl|wget)|(sh|bash|zsh)[[:space:]]+<\([[:space:]]*(curl|wget)'
)

# WARNING (English) — 正当な用途も在りうる; 人間が読むために炙り出す。
SKC_WARNING_PATTERNS=(
  'directive-injection|warning|^[[:space:]]*(system|assistant|developer)[[:space:]]*:'
  'secret-file-ref|warning|~/\.ssh/|~/\.aws/|/etc/(shadow|passwd)|(^|[^A-Za-z._])id_rsa([^A-Za-z]|$)|\.pem([^A-Za-z]|$)|\.p12([^A-Za-z]|$)|(^|[^A-Za-z.])\.env([^A-Za-z]|$)'
  'net-call-added|warning|(curl|wget)[[:space:]]|fetch\(|requests\.(get|post)|urllib\.request|http\.client|nc[[:space:]]+-'
  'suspicious-url|warning|(bit\.ly|tinyurl\.com|t\.co|is\.gd|goo\.gl|ow\.ly)/|aHR0c[A-Za-z0-9+/]{6,}'
  'rule-reversal|warning|(always|must)[[:space:]].{0,40}(never|must[[:space:]]not)|(security[_-]?review|fact[_-]?check|brand[_-]?check)[[:space:]].{0,24}(optional|skip|disable|unnecessary|not[[:space:]]+required)'
)

# WARNING (Japanese) — 既定で適用する(主読者は日本語)。
# severity は warning に固定(設計メモ参照: 語彙照合は言い換えで容易に回避できるため、
# JP の一致単独で "blocked" には昇格させない)。中核 4 つに限定する: 指示の上書き /
# 役割変更 / システムプロンプト参照 / 明示的な役割の無効化。
# 言語を際限なく増やす拡張はしない。
SKC_JP_WARNING_PATTERNS=(
  'instruction-override-jp|warning|(これまでの|以前の|上記の|前述の)[[:space:]]*(指示|命令|指令|指図|プロンプト|ルール).{0,8}(を)?[[:space:]]*(無視|忘れ|破棄|忘却|抹消|撤回)'
  'role-change-jp|warning|(以後|今後|これから)[[:space:]]*(あなたは|君は)'
  'system-prompt-ref-jp|warning|システムプロンプト(を|は|について|の内容)'
  'role-change-explicit-jp|warning|(役割|ロール|ペルソナ)[[:space:]]*(を)?[[:space:]]*(変更|変え|無効|無視)'
)

# SECRET markers — --include-secret-scan で opt-in。本物の認証情報を同梱した skill は
# 強い "do not install" シグナル(かつ作者にとっての漏洩リスク)。一致した値は出力に
# 現れる前にマスクされる(scan エンジン参照)。プレースホルダ語(EXAMPLE/DUMMY/TEST/
# SAMPLE/PLACEHOLDER/YOUR_/xxxxx)を含む行は、ドキュメント由来の false positive を
# 減らすためスキップされる。
SKC_SECRET_PATTERNS=(
  'aws-access-key|blocked|AKIA[0-9A-Z]{16}'
  'github-token|blocked|ghp_[A-Za-z0-9]{36}'
  'stripe-live|blocked|sk_live_[A-Za-z0-9]{16,}'
  'private-key-pem|blocked|-----BEGIN ([A-Z]+ )?PRIVATE KEY-----'
  'openai-key|blocked|sk-[A-Za-z0-9]{20,}'
  'slack-token|blocked|xox[baprs]-[A-Za-z0-9-]{10,}'
)

# patterns::secret_patterns — secret マーカーのパターンを 1 行ずつ出力する。
patterns::secret_patterns() {
  local p
  for p in "${SKC_SECRET_PATTERNS[@]}"; do printf '%s\n' "$p"; done
}

# patterns::all_patterns
# 有効な全パターンを "category|severity|regex" の形で 1 行ずつ出力する。
# 日本語 warning パターンは既定で適用される(主読者は日本語): opt-in フラグは無い。
patterns::all_patterns() {
  local p
  for p in "${SKC_BLOCKED_PATTERNS[@]}"; do printf '%s\n' "$p"; done
  for p in "${SKC_WARNING_PATTERNS[@]}"; do printf '%s\n' "$p"; done
  for p in "${SKC_JP_WARNING_PATTERNS[@]}"; do printf '%s\n' "$p"; done
}

# patterns::category_count — 有効なパターン数(走査出力用)。
patterns::category_count() {
  patterns::all_patterns | grep -c . || true
}

# ============================================================================
# (2) INSPECTION(照合)— 上のルールに全ファイルを照合する唯一の grep
# ============================================================================

# _skc_grep <regex> <file> [<ci>] -> 一致した "line:content" 行をグローバル _SKC_MATCHES
# (改行区切り、無ければ空)に取り込み、timeout を立てる。パターン走査と secret 走査の
# 両ループで共有し、grep+timeout+rc124 の骨格を 1 箇所に集約する。
# ci=1 で大小を無視して照合する(injection / role / remote-exec / warning 用: 文頭は
# 普通に大文字になるため、`Ignore all previous instructions` が素通りしていた)。
# 既定の ci=0 は大小を区別する — secret マーカー(AKIA / ghp_ / sk_live_ / PEM …)は
# 文字形式そのものが大小に依存するので、そこへ -i を波及させてはならない。
# 注意: 「検出パターンは常に -i で安全」ではない。suspicious-url の base64 断片
# (`aHR0c`)のように大小に意味があるものは -i で FP が増える — warning なら許容だが、
# 大小依存のパターンを blocked へ足すときは、ここの分岐を見直すこと。
# command substitution を介さずに呼ぶこと: `_skc_grep ...` は現在のシェルで走るので
# SKC_INCOMPLETE=1(fail-closed の timeout フラグ)が呼び出し側に残る。
# `$(_skc_grep ...)` 形式だとサブシェルで走り、この代入が黙って捨てられ fail-closed が
# 壊れる。grep 内部の $() は内部用で副作用は無い。
_skc_grep() {
  local rc flags="-nIE"
  [ "${3:-0}" = 1 ] && flags="-niIE"
  _SKC_MATCHES="$(timeout "$SKC_GREP_TIMEOUT" grep "$flags" -- "$1" "$2" 2>/dev/null)"; rc=$?
  [ "$rc" -eq 124 ] && SKC_INCOMPLETE=1
}

# ============================================================================
# (3) SCAN ENGINE(走査エンジン)— 走査・ハッシュ・マスク・fail-closed verdict(凍結コア)
# ============================================================================

SKC_MATCH_CAP="${SKC_MATCH_CAP:-20}"        # file+pattern ごとに記録する最大一致数
SKC_GREP_TIMEOUT="${SKC_GREP_TIMEOUT:-15}"  # grep 1 回あたりの秒数
SKC_EXCERPT_MAX="${SKC_EXCERPT_MAX:-200}"   # 一致行から保持する最大文字数

# 走査もハッシュもしないノイズ(ベンダ物・ビルド成果物)。
_skc_is_denied() {
  case "$1" in
    .git/*|*/.git/*|.git) return 0 ;;
    node_modules/*|*/node_modules/*) return 0 ;;
    .venv/*|*/.venv/*|__pycache__/*|*/__pycache__/*) return 0 ;;
    *.pyc) return 0 ;;
  esac
  return 1
}

# _skc_is_credential_file <relpath> -> 認証情報を入れる「型」のファイル名なら 0。
# skill が認証情報ファイルを同梱していること自体が、中身に依らず危険信号(red flag)。
# 中身は決して読まない — 存在だけで do_not_install にし、走査も hash もしない
# (対象の .env を読まないという配慮を保ったまま、shipped-secret の穴を塞ぐ)。
# `.env.example` 系(値を書かない慣習のテンプレ)は red flag にせず、通常ファイルとして
# 走査する: 本物の鍵をそこに置いても --include-secret-scan で捕まる。
_skc_is_credential_file() {
  case "${1##*/}" in                                   # basename で照合する
    .env.example|.env.sample|.env.template|.env.dist) return 1 ;;
    .env|.env.*) return 0 ;;
    *.pem|*.p12|*.pfx) return 0 ;;
    id_rsa|id_dsa|id_ecdsa|id_ed25519) return 0 ;;
    # 認証情報「専用」の型のみ挙げる。secrets.yaml / secrets.json のような一般語は
    # 正当な設定にも在りうるため、presence 直行(do_not_install)にはしない(FP を避ける)。
    .netrc|.aws-credentials|credentials|credentials.json|service-account.json) return 0 ;;
  esac
  return 1
}

# _skc_is_binary <relpath> -> 既知の「本物のバイナリ」拡張子(画像/フォント/アーカイブ/
# コンパイル済み/データ)なら 0。この種のファイルは NUL を含むのが当たり前なので、NUL の
# 存在自体を red flag にしない(そうしないと .png を同梱しただけの skill を弾く false
# positive になる)。逆に、ここに載らないファイル(拡張子なし / .conf / .yaml / .json /
# .md / .sh …)は「テキストのはず」= NUL 混入は隠蔽の痕跡として red flag 対象にする。
# 拡張子だけで判定する(中身は読まない、read-only・低コスト)。allowlist を保守的に保つ:
# 未知の拡張子は「テキスト扱い」に倒す方が安全側(NUL があれば flag される)。
_skc_is_binary() {
  case "${1##*/}" in
    *.png|*.jpg|*.jpeg|*.gif|*.webp|*.ico|*.bmp|*.tiff|*.pdf) return 0 ;;
    *.woff|*.woff2|*.ttf|*.otf|*.eot) return 0 ;;
    *.zip|*.gz|*.tar|*.tgz|*.bz2|*.xz|*.7z|*.rar|*.jar) return 0 ;;
    *.wasm|*.so|*.dylib|*.dll|*.exe|*.o|*.a|*.class|*.pyc|*.pyo) return 0 ;;
    *.bin|*.dat|*.db|*.sqlite|*.sqlite3|*.parquet|*.mo|*.npy|*.pkl|*.onnx|*.safetensors) return 0 ;;
    *.mp3|*.mp4|*.wav|*.flac|*.ogg|*.webm|*.mov|*.avi|*.mkv) return 0 ;;
  esac
  return 1
}

# _skc_has_nul <file> -> ファイルが NUL バイトを含めば 0。
# `grep -I` は NUL を見た時点でそのファイルの中身を一切見ない。テキストであるはずの
# ファイルに NUL を 1 個混ぜるだけで全パターンを回避できてしまう。role で絞らず、
# _skc_is_binary が false の全走査ファイル(config / manifest / 拡張子なし / 指示文 /
# スクリプト等)で NUL の存在自体を red flag にする(正当な skill は NUL を含まない)。
# bash 変数は NUL を保持できない($'\0' 直書き比較や $(cat f) は黙って NUL を落とす)ので、
# NUL 以外を捨てて(tr -cd)残ったバイト数を数える — NUL は tr|wc の中に留まり変数に入らない。
# wc の出力は環境により空白を伴うため除去してから比較する。
_skc_has_nul() {
  local n
  [ -r "$1" ] || return 1
  n="$(LC_ALL=C tr -cd '\000' < "$1" 2>/dev/null | LC_ALL=C wc -c)" || return 1
  n="${n//[[:space:]]/}"
  [ "${n:-0}" -gt 0 ]
}

# _skc_red_flag <reason> <relpath> — 走査の危険信号を 1 行記録する(reason US path)。
# 一致行を持たない検出(回避の痕跡・同梱認証情報)はここに載る。ファイルへ追記するのは
# scan::list_files がサブシェルで走りうるため(親のグローバル変数は設定できない)。
# reason は固定リテラル、path は sanitize 済み(制御文字を落とし secret をマスクする)。
_skc_red_flag() {
  [ -n "${SKC_REDFLAG_FILE:-}" ] || return 0
  printf '%s\037%s\n' "$1" "$(_skc_sanitize "$2")" >> "$SKC_REDFLAG_FILE"
}

# scan::list_files <dir> -> 相対パスを 1 行ずつ出力する(denylist 適用済み)。
# 走査対象から外す 3 経路で red flag を立てる: 制御文字を含むファイル名 / 対象外へ脱出する
# symlink / 同梱された認証情報ファイル。いずれも「読まずに」flag する。
scan::list_files() {
  local dir="$1" rel real base
  # symlink も含める(-type l): SKILL.md が target の「外」を指す symlink である skill は、
  # in-tree に見えて一度も走査されない(find -type f は link を飛ばす)= 評価のバイパス。
  # 各 symlink を解決する: target 内に留まり通常ファイルなら走査する; target の外へ
  # 出る(または解決できない)なら flag を立て(red flag)、決して読まない
  # (target の外への path traversal をしない)。
  while IFS= read -r -d '' rel; do
    rel="${rel#./}"
    [ -z "$rel" ] && continue
    _skc_is_denied "$rel" && continue
    # 認証情報ファイルは最初に落とす: 存在だけで red flag、中身は決して読まない。
    if _skc_is_credential_file "$rel"; then
      _skc_red_flag shipped-credential-file "$rel"
      continue
    fi
    case "$rel" in
      *[$'\001'-$'\037']*)
        _skc_red_flag bad-filename "$rel"
        continue ;;
    esac
    if [ -L "$dir/$rel" ]; then
      real="" ; base=""
      if command -v realpath >/dev/null 2>&1; then
        real="$(realpath -m -- "$dir/$rel" 2>/dev/null)"
        base="$(realpath -m -- "$dir" 2>/dev/null)"
      fi
      if [ -n "$real" ] && { [ "$real" = "$base" ] || case "$real" in "$base"/*) true ;; *) false ;; esac; }; then
        [ -f "$dir/$rel" ] && printf '%s\n' "$rel"   # in-tree の通常ファイル: 走査する
      else
        _skc_red_flag symlink-escape "$rel"          # target の外へ脱出
      fi
      continue
    fi
    printf '%s\n' "$rel"
  done < <(cd "$dir" 2>/dev/null && find . \( -type f -o -type l \) -print0 2>/dev/null)
}

# _skc_content_hash_from_list <dir> <list_file> -> (relpath + US + sha256(content)) に
# 対する "sha256:<hex>"。決定性のため LC_ALL=C でソートする。<list_file> は事前計算済み
# の scan::list_files 出力(1 行 1 relpath)。sha256sum は timeout で包み、病的なファイル
# が指紋計算を hang させないようにする; 部分ハッシュは SKC_INCOMPLETE に連動させない
# (content_hash は識別子であって検出シグナルではない)。
_skc_content_hash_from_list() {
  local dir="$1" list="$2" rel sum
  command -v sha256sum >/dev/null 2>&1 || { echo "sha256:unavailable"; return 0; }
  sum="$(LC_ALL=C sort "$list" | while IFS= read -r rel; do
    printf '%s\037%s\n' "$rel" "$(timeout "$SKC_GREP_TIMEOUT" sha256sum "$dir/$rel" 2>/dev/null | cut -d' ' -f1)"
  done | sha256sum | cut -d' ' -f1)"
  echo "sha256:$sum"
}

# _skc_redact <string> -> secret パターンの一致をマスクする(secret_hits だけでなく
# hits の excerpt チャネルでもマスク不変条件を保つ)。secret は warning パターンに一致
# する行に同居しうる(例: net-call 行の Authorization ヘッダ); これが無いと生のトークン
# が hits[].excerpt にそのまま載ってしまう。
_skc_redact() {
  local s="$1" entry regex
  if declare -F patterns::secret_patterns >/dev/null 2>&1; then
    while IFS= read -r entry; do
      regex="${entry##*|}"
      [ -z "$regex" ] && continue
      s="$(printf '%s' "$s" | sed -E "s/${regex}/[REDACTED-SECRET]/g" 2>/dev/null || printf '%s' "$s")"
    done < <(patterns::secret_patterns)
  fi
  printf '%s' "$s"
}

# _skc_sanitize <string> -> 印字可能・区切り文字なし・secret マスク済み・切り詰め済み。
# 切り詰めは bash の部分文字列(UTF-8 ロケール下では文字単位)を使い、マルチバイト文字
# を途中で割らないようにする。割ると不正な UTF-8 になり、後段の `jq -R` が壊れうる。
_skc_sanitize() {
  local s
  s="$(printf '%s' "$1" | tr -d '\000-\037')"
  s="$(_skc_redact "$s")"
  printf '%s' "${s:0:$SKC_EXCERPT_MAX}"
}

# _skc_has_placeholder <line> -> 行が docs/例示 に見えれば 0(secret hit をスキップ)
_skc_has_placeholder() {
  printf '%s' "$1" | grep -qiE 'EXAMPLE|DUMMY|TEST|SAMPLE|PLACEHOLDER|YOUR_|<your-|xxxxx'
}

# _skc_mask <token> -> 先頭 4 文字 + "***"(生の secret は関数の外に出さない)
_skc_mask() {
  printf '%s***' "$(printf '%s' "$1" | cut -c1-4)"
}

# _skc_role <relpath> -> instruction | executable | other を出力する。
# 分類はパス/拡張子のみによる; 出力に添える補助的な文脈。
# 指示文ファイル(任意の *.md / *.txt)は "instruction" とラベルする — SKILL.md・
# AGENTS.md・CLAUDE.md など、エージェントが読みうる散文を対称に扱う。
# どのツールの指示文ファイル名も特別扱いしない: すべてのファイルは一律に走査され
# ("scan superset")、role は拡張子だけから導く。
_skc_role() {
  case "$1" in
    *.sh|*.bash|*.zsh|*.fish|*.js|*.mjs|*.cjs|*.ts|*.py|*.rb|*.pl|*.php)
      echo "executable"; return 0 ;;
    *.md|*.txt)
      echo "instruction"; return 0 ;;
  esac
  echo "other"
}


# _skc_emit_json <dir> <content_hash> <files> <patterns> <signal>
#                <hits_tmp> <secret_tmp> <redflag_tmp>  -> JSON を stdout に出力する。
# jq があれば使う; 無ければ最小限の(それでも妥当な)degraded オブジェクトを出力する。
_skc_emit_json() {
  local dir="$1" chash="$2" files="$3" pcount="$4" signal="$5"
  local hits_tmp="$6" secret_tmp="$7" redflag_tmp="$8"
  local ts; ts="$(date -u +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || echo unknown)"

  if command -v jq >/dev/null 2>&1; then
    local hits_json secret_json redflag_json
    hits_json="$(jq -R -s '
      split("\n") | map(select(length>0)) | map(split(""))
      | map({category:.[0], severity:.[1], file:.[2],
             line:((.[3]|tonumber?) // .[3]), role:.[4], excerpt:.[5]})' "$hits_tmp")"
    secret_json="$(jq -R -s '
      split("\n") | map(select(length>0)) | map(split(""))
      | map({category:.[0], file:.[1], line:((.[2]|tonumber?) // .[2]), masked:.[3]})' "$secret_tmp")"
    # 一致行を持たない検出。同じ理由が複数ファイルに立つので unique で畳む。
    # 区切りは hits / secret と同じ US バイト。
    redflag_json="$(jq -R -s '
      split("\n") | map(select(length>0)) | map(split(""))
      | map({reason:.[0], file:.[1]}) | unique' "$redflag_tmp")"
    jq -n \
      --arg sv "$(patterns::schema_version)" --arg td "$dir" \
      --arg ch "$chash" --argjson fs "${files:-0}" --argjson pc "${pcount:-0}" \
      --arg sig "$signal" --argjson hits "$hits_json" --argjson secrets "$secret_json" \
      --argjson flags "$redflag_json" --arg ts "$ts" \
      '{schema_version:$sv, tool:"skill-screen", target_dir:$td,
        content_hash:$ch, files_scanned:$fs, pattern_count:$pc,
        candidate_signal:$sig, hits:$hits, secret_hits:$secrets,
        red_flags:$flags, scanned_at:$ts}'
  else
    # degraded 経路: jq なし。件数のみで一致ごとの詳細は出さない(それでも妥当な JSON)。
    # grep -c は無一致時に "0" を出力して exit 1 する; `|| true` はその "0" を保ち、もう
    # 一つ足さない(以前の `|| echo 0` は余分な "0\n0" を生んでいた)。
    local nhits nsec nflag dir_esc
    nhits="$(grep -c . "$hits_tmp" 2>/dev/null || true)"; nhits="${nhits:-0}"
    nsec="$(grep -c . "$secret_tmp" 2>/dev/null || true)"; nsec="${nsec:-0}"
    nflag="$(grep -c . "$redflag_tmp" 2>/dev/null || true)"; nflag="${nflag:-0}"
    # target_dir は操作者が制御する; \ と " をエスケープし制御文字を落とすことで、
    # 細工したディレクトリ名がこの手組み経路の JSON を壊せないようにする。
    dir_esc="$(printf '%s' "$dir" | tr -d '\000-\037' | sed -e 's/\\/\\\\/g' -e 's/"/\\"/g')"
    printf '{"schema_version":"%s","tool":"skill-screen","target_dir":"%s",' \
      "$(patterns::schema_version)" "$dir_esc"
    printf '"content_hash":"%s","files_scanned":%s,"pattern_count":%s,' \
      "$chash" "${files:-0}" "${pcount:-0}"
    printf '"candidate_signal":"%s","hits_count":%s,"secret_hits_count":%s,' \
      "$signal" "$nhits" "$nsec"
    printf '"red_flags_count":%s,' "$nflag"
    printf '"degraded":"jq not found: counts only","scanned_at":"%s"}\n' "$ts"
  fi
}

# scan::run <dir> <secret:0|1> <json_out_path>
# 結果 JSON を <json_out_path> に書き、グローバル SKC_SIGNAL を次のいずれかに設定する:
#   no_signal | review_needed | do_not_install | scan-error
scan::run() {
  local dir="$1" secret="$2" out="$3"
  SKC_SIGNAL="scan-error"
  SKC_INCOMPLETE=0

  if [ ! -d "$dir" ]; then
    _skc_emit_json "$dir" "sha256:unavailable" 0 0 "scan-error" \
      /dev/null /dev/null /dev/null > "$out"
    return 0
  fi

  local hits_tmp secret_tmp files_tmp
  hits_tmp="$(mktemp)"; secret_tmp="$(mktemp)"; files_tmp="$(mktemp)"
  SKC_REDFLAG_FILE="$(mktemp)"
  # どの return 経路でも全 temp を掃除する。mktemp 群の「後」に設定するので、上の
  # dir 不在の早期 return(temp がまだ存在しない時点で走る)では発火しない。関数内で
  # 設定した RETURN trap は関数スコープ(functrace なし)= 呼び出し側に漏れない(verified)。
  trap 'rm -f "$hits_tmp" "$secret_tmp" "$files_tmp" "$SKC_REDFLAG_FILE"' RETURN

  # ディレクトリの走査は厳密に 1 回だけ; キャッシュしたリストをファイル数・content
  # hash・走査ループで再利用する(以前は別々に 3 回走査していた)。
  scan::list_files "$dir" > "$files_tmp"
  local files_scanned content_hash pattern_count
  files_scanned="$(grep -c . "$files_tmp" || true)"
  content_hash="$(_skc_content_hash_from_list "$dir" "$files_tmp")"
  pattern_count="$(patterns::category_count)"

  local rel entry category rest severity regex line content excerpt role
  while IFS= read -r rel; do
    role="$(_skc_role "$rel")"

    # `grep -I` は NUL を 1 個見ただけでファイルの中身を読まない = NUL 混入で全パターンを
    # 回避できる。テキストであるはずのファイル(既知バイナリ拡張子でない全ファイル)は
    # NUL の存在自体を red flag にする。role=other の config/manifest/拡張子なしも対象に
    # 含める(v3 の instruction/executable 限定では setup.conf 等が素通りしていた)。
    # 本物のバイナリ(画像/フォント/データ)は NUL を含むのが当然なので除外 = hash のみ。
    if ! _skc_is_binary "$rel"; then
      _skc_has_nul "$dir/$rel" && _skc_red_flag nul-in-file "$rel"
    fi

    while IFS= read -r entry; do
      [ -z "$entry" ] && continue
      category="${entry%%|*}"; rest="${entry#*|}"
      severity="${rest%%|*}"; regex="${rest#*|}"
      _skc_grep "$regex" "$dir/$rel" 1     # ci=1: 文頭の大文字化で素通りさせない
      [ -z "$_SKC_MATCHES" ] && continue
      printf '%s\n' "$_SKC_MATCHES" | head -n "$SKC_MATCH_CAP" | while IFS= read -r m; do
        [ -z "$m" ] && continue
        line="${m%%:*}"; content="${m#*:}"
        excerpt="$(_skc_sanitize "$content")"
        printf '%s\037%s\037%s\037%s\037%s\037%s\n' \
          "$category" "$severity" "$rel" "$line" "$role" "$excerpt" >> "$hits_tmp"
      done
    done < <(patterns::all_patterns)

    if [ "$secret" = 1 ]; then
      while IFS= read -r entry; do
        [ -z "$entry" ] && continue
        category="${entry%%|*}"; rest="${entry#*|}"; regex="${rest#*|}"
        _skc_grep "$regex" "$dir/$rel"        # ci=0: トークン形式は大小に依存する
        [ -z "$_SKC_MATCHES" ] && continue
        printf '%s\n' "$_SKC_MATCHES" | head -n "$SKC_MATCH_CAP" | while IFS= read -r m; do
          [ -z "$m" ] && continue
          line="${m%%:*}"; content="${m#*:}"
          _skc_has_placeholder "$content" && continue
          local token; token="$(printf '%s' "$content" | grep -oE -- "$regex" 2>/dev/null | head -n1)"
          printf '%s\037%s\037%s\037%s\n' \
            "$category" "$rel" "$line" "$(_skc_mask "$token")" >> "$secret_tmp"
        done
      done < <(patterns::secret_patterns)
    fi
  done < "$files_tmp"

  # signal: 不完全な走査、または制御文字/脱出するファイル名があれば fail-closed。
  # severity はフィールド 2(US 区切り); awk -F'\037' は 8 進エスケープを解釈するが、
  # grep は \037 を US バイトとして扱わない。awk が使えなければ fail-closed にする:
  # いかなる hit も、黙って格下げせず blocked として扱う。
  local has_blocked=0
  if command -v awk >/dev/null 2>&1; then
    awk -F'\037' '$2=="blocked"{found=1} END{exit(found?0:1)}' "$hits_tmp" 2>/dev/null && has_blocked=1
  elif [ -s "$hits_tmp" ]; then
    has_blocked=1
  fi
  local signal="no_signal"
  if [ -s "$secret_tmp" ] || [ "$has_blocked" = 1 ] \
     || [ "$SKC_INCOMPLETE" = 1 ] || [ -s "$SKC_REDFLAG_FILE" ]; then
    signal="do_not_install"
  elif [ -s "$hits_tmp" ]; then
    signal="review_needed"
  fi
  SKC_SIGNAL="$signal"

  _skc_emit_json "$dir" "$content_hash" "$files_scanned" \
    "$pattern_count" "$signal" "$hits_tmp" "$secret_tmp" "$SKC_REDFLAG_FILE" > "$out"
  # temp はこの関数冒頭で設定した RETURN trap が削除する。
}

# ============================================================================
# (4) DRIVER(駆動部)— 引数解析・出力(read-only = 対象を一切書き換えない)
# ============================================================================

target="" ; secret=0 ; want_json=0

need_val() { [ "$1" -ge 2 ] || { printf 'skill-screen: %s requires a value / %s には値が必要\n' "$2" "$2" >&2; exit 3; }; }
while [ $# -gt 0 ]; do
  case "$1" in
    --target) need_val "$#" --target; target="$2"; shift 2 ;;
    --target=*) target="${1#*=}"; shift ;;
    --include-secret-scan) secret=1; shift ;;
    --json) want_json=1; shift ;;
    -h|--help) usage; exit 0 ;;
    *) printf 'skill-screen: unknown argument / 不明な引数: %s\n' "$1" >&2; usage >&2; exit 3 ;;
  esac
done

if [ -z "$target" ]; then
  printf 'skill-screen: --target <dir> is required / --target <dir> は必須\n' >&2; usage >&2; exit 3
fi

json_out="$(mktemp)"
trap 'rm -f "$json_out"' EXIT

scan::run "$target" "$secret" "$json_out"
signal="$SKC_SIGNAL"

# --- 出力 / output ---
if [ "$want_json" = 1 ]; then
  cat "$json_out"
else
  printf 'skill-screen  verdict=%s\n' "$signal"
  case "$signal" in
    no_signal)      printf '  ルールに一致なし。これは安全の証明では「ない」。\n'
                    printf '  No rule matched. This is NOT a proof of safety.\n' ;;
    review_needed)  printf '  warning レベルの一致あり。導入前に必ず確認すること:\n'
                    printf '  Warning-level matches. Read them before installing:\n' ;;
    do_not_install) printf '  blocked レベルの一致(または走査の危険信号)。そのままでは導入しないこと:\n'
                    printf '  Blocked-level matches (or a scan red flag). Do not install as-is:\n' ;;
    scan-error)     printf '  対象を走査できなかった(ディレクトリ不在?)。\n'
                    printf '  Could not scan the target (missing dir?).\n' ;;
  esac
  if [ "$signal" = "review_needed" ] || [ "$signal" = "do_not_install" ]; then
    if command -v jq >/dev/null 2>&1; then
      # red flag は一致行を持たない(回避の痕跡・同梱認証情報)。先に出さないと
      # do_not_install なのに理由が 1 行も出ない、という読めない出力になる。
      jq -r '.red_flags[]? | "    [red-flag] \(.reason)  \(.file)"' "$json_out" 2>/dev/null
      jq -r '.hits[]? | "    [\(.severity)] \(.category)  \(.file):\(.line)"' "$json_out" 2>/dev/null | sort -u
      jq -r '.secret_hits[]? | "    [secret] \(.category)  \(.file):\(.line)  \(.masked)"' "$json_out" 2>/dev/null
    else
      printf '    (一致ごとの内訳には jq を導入; 生出力は --json で実行)\n'
      printf '    (install jq for a per-hit breakdown; run with --json for raw output)\n'
    fi
    printf '  次へ: この出力 + %s/SKILL.md の Stage 2 プロンプトを LLM に渡して意図を判定する。\n' "$_self_dir"
    printf '  Next: hand this output + the Stage 2 prompt in %s/SKILL.md to an LLM for intent.\n' "$_self_dir"
  fi
fi

case "$signal" in
  no_signal) exit 0 ;;
  review_needed) exit 1 ;;
  do_not_install) exit 2 ;;
  *) exit 3 ;;
esac
